// {{ ansible_managed }}

Unattended-Upgrade::Allowed-Origins {
	"${distro_id}:${distro_codename}";
	"${distro_id}:${distro_codename}-security";
	"${distro_id}:stable-security";
	"${distro_id}ESMApps:${distro_codename}-apps-security";
	"${distro_id}ESM:${distro_codename}-infra-security";
{% for origin in apt_unattended_upgrades_origins_extra %}
	"{{ origin }}";
{% endfor %}
};

Unattended-Upgrade::Package-Block-List {
{% for pkg in apt_unattended_upgrades_package_blocklist %}
	"{{ pkg }}";
{% endfor %}
};

Unattended-Upgrade::Remove-Unused-Kernel-Packages "{{ apt_unattended_upgrades_remove_unused_kernel_packages | lower }}";
Unattended-Upgrade::Remove-New-Unused-Dependencies "{{ apt_unattended_upgrades_remove_new_unused_dependencies | lower }}";
Unattended-Upgrade::Remove-Unused-Dependencies "{{ apt_unattended_upgrades_remove_unused_dependencies | lower }}";
Unattended-Upgrade::Automatic-Reboot "{{ apt_unattended_upgrades_automatic_reboot | lower }}";
Unattended-Upgrade::Automatic-Reboot-WithUsers "{{ apt_unattended_upgrades_automatic_reboot_with_users | lower }}";
Unattended-Upgrade::Automatic-Reboot-Time "{{ apt_unattended_upgrades_automatic_reboot_time }}";
